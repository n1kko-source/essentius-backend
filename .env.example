SUPABASE_URL=
SUPABASE_KEY=

# --- Bloque final APIs (gratis / free tier) — GUIA_INICIO.md §8 ---
# Gemini (AI Studio, sin tarjeta): https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Modelo free-tier (alias lite actual): gemini-flash-lite-latest
# Alternativas: gemini-3.1-flash-lite, gemini-2.5-flash
GEMINI_MODEL=gemini-flash-lite-latest
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Tavily free: https://app.tavily.com/home
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=3

# false = consumir Gemini real (requiere GOOGLE_API_KEY)
USE_MOCK_AI=true

AUTH_REQUIRED=false
NOTES_BACKEND=auto
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.56.1:3000
